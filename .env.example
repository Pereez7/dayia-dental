VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=http://localhost:5173

# Public WhatsApp number for payment receipts, including country code.
# Example for Bolivia: 59170000000
VITE_DAYIA_BILLING_WHATSAPP=

# Use true only for local development or product demos.
# The commercial MVP should use Supabase login as the main flow.
VITE_ENABLE_DEMO_MODE=false

# WhatsApp API secrets are configured in Supabase Secrets, not frontend env:
# WHATSAPP_ACCESS_TOKEN
# WHATSAPP_SEND_ENABLED
# WHATSAPP_VERIFY_TOKEN
