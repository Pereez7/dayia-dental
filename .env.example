VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=http://localhost:5173

# Use true only for local development or product demos.
# The commercial MVP should use Supabase login as the main flow.
VITE_ENABLE_DEMO_MODE=false

# Frontend UX switch only. The Edge Function still requires the protected
# DAYIA_PLATFORM_CREATE_ENABLED Supabase secret to be exactly "true".
VITE_DAYIA_PLATFORM_CREATE_ENABLED=false

# WhatsApp API secrets are configured in Supabase Secrets, not frontend env:
# WHATSAPP_ACCESS_TOKEN
# WHATSAPP_SEND_ENABLED
# WHATSAPP_VERIFY_TOKEN
